{
  "name": "@trucklinemp/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the TrucklineMP public API, OAuth, and webhooks",
  "license": "MIT",
  "author": "TrucklineMP",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./oauth": {
      "types": "./dist/oauth-entry.d.ts",
      "import": "./dist/oauth-entry.js",
      "require": "./dist/oauth-entry.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks-entry.d.ts",
      "import": "./dist/webhooks-entry.js",
      "require": "./dist/webhooks-entry.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/oauth-entry.ts src/webhooks-entry.ts --format cjs,esm --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trucklinemp/sdk.git",
    "directory": "."
  },
  "homepage": "https://docs.trucklinemp.com/guides/developers/sdk/",
  "bugs": {
    "url": "https://github.com/trucklinemp/sdk/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "truckline",
    "trucklinemp",
    "ets2",
    "ats",
    "api",
    "sdk",
    "oauth",
    "webhooks"
  ],
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
