{
  "name": "@trucklinemp/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the TrucklineMP public API",
  "license": "MIT",
  "author": "TrucklineMP",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trucklinemp/sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "keywords": [
    "truckline",
    "trucklinemp",
    "ets2",
    "ats",
    "api",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
